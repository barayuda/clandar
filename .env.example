PORT=8080
LOG_LEVEL=info

# Local SQLite — used when TURSO_DATABASE_URL is not set (local dev)
DB_PATH=./data/clandar.db

# Turso cloud SQLite — takes priority over DB_PATH when set
# Get these from: https://app.turso.tech → your database → Connect
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Optional — improves holiday coverage for ASEAN countries
CALENDARIFIC_API_KEY=your_key_here
